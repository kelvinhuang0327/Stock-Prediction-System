    "STALE_DATA",
    "MISSING_DATA",
    "GUARDRAIL_FAIL",
    "BLOCKED"
  ],
  "status_rules": {
    "PASS": "freshnessAlert.alertLevel = FRESH and persisted regime available",
    "PASS_WITH_WARNINGS": "freshnessAlert.alertLevel = STALE",
    "STALE_DATA": "freshnessAlert.alertLevel = CRITICAL_STALE",
    "MISSING_DATA": "persisted regime not available (isAvailable = false)",
    "GUARDRAIL_FAIL": "freshnessAlert.alertLevel = FUTURE_DATE_ERROR",
    "BLOCKED": "catastrophic failure — manual intervention required"
  },
  "field_schemas": {
    "marketRegime": {
      "regimeLabel": "string | null",
