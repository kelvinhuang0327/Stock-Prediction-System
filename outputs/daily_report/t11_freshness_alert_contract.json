{
  "contract_version": "t11_v1",
  "task": "T-11 Freshness Alert for MarketRegimeResult",
  "generated_date": "2026-05-06",
  "alert_levels": {
    "FRESH": {
      "rule": "freshnessLagDays <= 3",
      "requiresAction": false,
      "message_template": null,
      "description": "Regime data is current. No action required."
    },
    "STALE": {
      "rule": "freshnessLagDays >= 4 AND freshnessLagDays <= 7",
      "requiresAction": true,
      "message_template": "MarketRegimeResult is stale by {lag} calendar days.",
      "description": "Regime data is mildly stale. Refresh recommended."
    },
    "CRITICAL_STALE": {
      "rule": "freshnessLagDays > 7",
      "requiresAction": true,
      "message_template": "MarketRegimeResult is critically stale by {lag} calendar days. Immediate refresh required.",
      "description": "Regime data is critically stale. Immediate refresh required."
    },
    "MISSING": {
      "rule": "context.isAvailable === false",
      "requiresAction": true,
      "message_template": "No MarketRegimeResult found.",
      "description": "No regime records exist in the database."
    },
    "FUTURE_DATE_ERROR": {
      "rule": "context.freshnessStatus === 'FUTURE_DATE_ERROR' (persisted date > currentDate)",
      "requiresAction": true,
      "message_template": "Persisted regime date {date} is after currentDate {currentDate}.",
      "description": "Data integrity error: regime date is in the future."
    }
  },
