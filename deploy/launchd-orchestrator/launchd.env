# launchd.env.example
# Copy to deploy/launchd-orchestrator/launchd.env and adjust for your machine.

# PATH for launchd shell context
LAUNCHD_PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"

# Backend service (required)
BACKEND_PORT=3000
BACKEND_CMD='npm run dev -- -H 127.0.0.1 -p 3000'
BACKEND_HEALTH_URL='http://127.0.0.1:3000/api/system/health'

# Frontend service:
# - shared: frontend 與 backend 共用同一個 Next.js 進程（本專案預設）
# - separate: 需設定 FRONTEND_CMD 與 FRONTEND_PORT
FRONTEND_MODE='shared'
FRONTEND_PORT=3000
FRONTEND_CMD=''
FRONTEND_HEALTH_URL='http://127.0.0.1:3000/'

# Startup checks
HEALTH_RETRIES=45
HEALTH_RETRY_INTERVAL_SEC=2
MONITOR_INTERVAL_SEC=20

# Smoke check after startup
SMOKE_COMMAND='curl -fsS http://127.0.0.1:3000/api/orchestrator/summary >/dev/null'

# Worker daemon behavior
WORKER_DAEMON_INTERVAL_SEC=60
WORKER_DAEMON_FAIL_FAST=0

# External worker command used by orchestrator worker tick.
# Placeholders: {task_id} {prompt_path} {contract_path} {provider} {objective}
AGENT_ORCHESTRATOR_WORKER_CMD='bash scripts/orchestrator_worker_external.sh {task_id} "{prompt_path}" "{contract_path}" "{provider}" "{objective}"'
